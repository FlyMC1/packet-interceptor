{
    "name": "bedrock-packet-interceptor",
    "version": "0.0.2",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "desktop": "npm run build && electron .",
        "dist:win": "npm run build && electron-builder --win nsis",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "prettier --plugin-search-dir . --check . && eslint .",
        "format": "prettier --plugin-search-dir . --write ."
    },
    "devDependencies": {
        "@sveltejs/adapter-node": "^1.3.1",
        "@sveltejs/kit": "^1.20.4",
        "@types/node": "^20.4.0",
        "@typescript-eslint/eslint-plugin": "^5.45.0",
        "@typescript-eslint/parser": "^5.45.0",
        "@zerodevx/svelte-toast": "^0.9.5",
        "autoprefixer": "^10.4.15",
        "cssnano": "^6.0.1",
        "electron": "^36.2.1",
        "electron-builder": "^24.13.3",
        "eslint": "^8.28.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-svelte": "^2.30.0",
        "postcss": "^8.4.28",
        "prettier": "^2.8.0",
        "prettier-plugin-svelte": "^2.10.1",
        "svelte": "^4.0.0",
        "svelte-check": "^3.4.3",
        "svelte-json-tree": "^2.1.0",
        "tailwindcss": "^3.3.3",
        "tslib": "^2.4.1",
        "typescript": "^5.0.0",
        "vite": "^4.3.6"
    },
    "build": {
        "appId": "com.flymc.packetinterceptor",
        "productName": "Bedrock Packet Interceptor",
        "files": [
            "build/**/*",
            "electron/**/*",
            "package.json",
            "node_modules/**/*"
        ],
        "asar": true,
        "directories": {
            "output": "release"
        },
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "type": "module",
    "dependencies": {
        "bedrock-protocol": "^3.41.0"
    }
}
